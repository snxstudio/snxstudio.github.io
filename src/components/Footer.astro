---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="footer">
  <!-- Top ticker -->
  <div class="footer-ticker" aria-hidden="true">
    <div class="marquee marquee-fast">
      <div class="marquee-track">
        <span class="footer-ticker-item">Bengaluru — IST</span><span class="footer-sep">★</span>
        <span class="footer-ticker-item">Hand-shipped software</span><span class="footer-sep">★</span>
        <span class="footer-ticker-item">AI-native builds</span><span class="footer-sep">★</span>
        <span class="footer-ticker-item">UX teardowns welcome</span><span class="footer-sep">★</span>
        <span class="footer-ticker-item">Bengaluru — IST</span><span class="footer-sep">★</span>
        <span class="footer-ticker-item">Hand-shipped software</span><span class="footer-sep">★</span>
        <span class="footer-ticker-item">AI-native builds</span><span class="footer-sep">★</span>
        <span class="footer-ticker-item">UX teardowns welcome</span><span class="footer-sep">★</span>
      </div>
    </div>
  </div>

  <div class="container footer-inner">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <Logo />
        <p class="footer-tagline serif-italic">
          An AI-native technology partner —
          built around senior engineering and an aversion to vapourware.
        </p>
        <div class="footer-clock" aria-live="polite">
          <span class="footer-clock-label">Studio time</span>
          <span class="footer-clock-time" id="footer-clock">— : —</span>
          <span class="footer-clock-loc">Bengaluru · IST</span>
        </div>
      </div>

      <!-- Navigate -->
      <div class="footer-col">
        <h4 class="footer-heading">Navigate</h4>
        <ul class="footer-list" role="list">
          <li><a href="/services" class="footer-link">Services</a></li>
          <li><a href="/work" class="footer-link">Selected Work</a></li>
          <li><a href="/about" class="footer-link">Studio</a></li>
          <li><a href="/opensource" class="footer-link">Open Source</a></li>
          <li><a href="/blog" class="footer-link">Field Notes</a></li>
          <li><a href="/contact" class="footer-link">Contact</a></li>
        </ul>
      </div>

      <!-- Capabilities -->
      <div class="footer-col">
        <h4 class="footer-heading">Capabilities</h4>
        <ul class="footer-list" role="list">
          <li><a href="/services#ai" class="footer-link">AI Native</a></li>
          <li><a href="/services#iot" class="footer-link">Industrial IoT</a></li>
          <li><a href="/services#web" class="footer-link">Web Platforms</a></li>
          <li><a href="/services#design" class="footer-link">Design &amp; UX Audits</a></li>
          <li><a href="/services#cloud" class="footer-link">Cloud &amp; DevEx</a></li>
          <li><a href="/services#agritech" class="footer-link">AgriTech Systems</a></li>
          <li><a href="/services#advisory" class="footer-link">Technical Advisory</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div class="footer-col">
        <h4 class="footer-heading">Connect</h4>
        <ul class="footer-list" role="list">
          <li><a href="mailto:hello@wearesnx.studio" class="footer-link">hello@wearesnx.studio</a></li>
          <li><a href="https://github.com/mayurrawte" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub ↗</a></li>
          <li><a href="https://in.linkedin.com/in/mayurrawte" target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn ↗</a></li>
          <li><a href="https://medium.com/@rawte.mayur" target="_blank" rel="noopener noreferrer" class="footer-link">Medium ↗</a></li>
          <li><a href="/contact" class="footer-link">Book a strategy call</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">
        <span>© {year} SNX Studio.</span>
        <span class="footer-copy-rule serif-italic">Made between Bengaluru and the next deploy.</span>
      </p>
      <div class="footer-legal">
        <a href="/about" class="footer-legal-link">Studio note</a>
        <span aria-hidden="true">·</span>
        <a href="mailto:hello@wearesnx.studio" class="footer-legal-link">Press &amp; Speaking</a>
      </div>
    </div>
  </div>

  <!-- Massive watermark -->
  <div class="footer-watermark" aria-hidden="true">
    <span>SN</span><span class="wm-x">X</span>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    background-color: var(--bg-alt);
    border-top: 1px solid var(--border);
  }

  .footer-ticker {
    border-bottom: 1px solid var(--border);
    background: var(--accent);
    color: #fff;
    padding: 0.6rem 0;
  }
  .footer-ticker .marquee-track { gap: 1.5rem; padding-right: 1.5rem; }
  .footer-ticker-item {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .footer-sep {
    color: rgba(255,255,255,0.65);
    font-family: var(--font-display);
    font-size: 0.9rem;
    margin: 0 1rem;
  }

  .footer-inner {
    position: relative;
    z-index: 2;
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
  }

  .footer-brand {
    max-width: 360px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .footer-tagline {
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--ink-2);
  }

  .footer-clock {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .footer-clock-time {
    color: var(--ink);
    font-feature-settings: "tnum" on;
  }
  .footer-clock-loc { color: var(--muted); }
  .footer-clock-label::after { content: ' · '; }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .footer-heading {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .footer-link {
    font-size: 0.95rem;
    color: var(--ink-2);
    transition: color 0.25s ease;
  }
  .footer-link:hover { color: var(--accent); }

  .footer-bottom {
    margin-top: clamp(3rem, 6vw, 5rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    display: inline-flex;
    gap: 0.625rem;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .footer-copy-rule {
    font-family: var(--font-serif);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.95rem;
    color: var(--ink-2);
  }
  .footer-legal {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    display: inline-flex;
    gap: 0.5rem;
  }
  .footer-legal-link { transition: color 0.25s ease; }
  .footer-legal-link:hover { color: var(--accent); }

  /* Watermark */
  .footer-watermark {
    position: absolute;
    left: 50%;
    bottom: -3vw;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(10rem, 28vw, 28rem);
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: var(--ink);
    opacity: 0.05;
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
  }
  .wm-x { color: var(--accent); opacity: 1; }

  @media (max-width: 880px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  function tickClock() {
    const el = document.getElementById('footer-clock');
    if (!el) return;
    const fmt = new Intl.DateTimeFormat('en-IN', {
      hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'Asia/Kolkata'
    });
    el.textContent = fmt.format(new Date());
  }
  tickClock();
  setInterval(tickClock, 30000);
</script>
