---
import Mark from '../Marks.astro';

const notes = [
  {
    num: 'N°01',
    kicker: 'A solution document',
    title: 'IRCTC: diagnosing Tatkal and designing what should replace it',
    excerpt: 'The 10 AM Tatkal rush is the load-bearing wall — every other failure descends from it. A two-track lottery, a Booking Reputation Score, and an atomic booking pipeline that ends "money debited, no ticket". 12 pages, end-to-end.',
    tags: ['UX teardown', 'Public systems', 'Queueing'],
    read: '30 min',
    status: 'Published',
  },
  {
    num: 'N°02',
    kicker: 'A migration story',
    title: 'Why we ditched Python for Go',
    excerpt: 'A weekend rewrite of a hot FastAPI endpoint cut p99 latency 10×, dropped infrastructure cost by 68%, and made 3 AM pages stop. The honest story — including the three weeks of velocity we lost teaching the team a new language.',
    tags: ['Go', 'FastAPI', 'Performance'],
    read: '9 min',
    status: 'Published',
  },
  {
    num: 'N°03',
    kicker: 'A note on AI',
    title: 'AI isn\'t here to replace developers — it\'s here to replace the stuff we secretly hate',
    excerpt: 'The most expensive bug we never shipped wasn\'t in the code — it was in how we worked. A note on PR review queues, the cost of context-switching, and the small AI tool that bought a team back its senior engineering hours.',
    tags: ['AI', 'Engineering ops', 'Open source'],
    read: '7 min',
    status: 'Published',
  },
];
---

<section class="notes section" id="field-notes">
  <div class="container-wide">
    <header class="notes-header">
      <div>
        <span class="tape tape-tilt-l">— field notes —</span>
        <h2 class="notes-h2">
          Theses, teardowns,<br/>
          <span class="notes-circled">
            <span class="serif-italic">and other opinions</span>
            <span class="notes-mark"><Mark name="ink-circle" /></span>
          </span><br/>
          you didn't ask for.
        </h2>
      </div>
      <p class="notes-sub">
        A working studio writes — about the systems we admire, the ones we'd
        redesign, and the ones we wish someone would take a saw to. Long-form,
        slow-published, often uncomfortable.
      </p>
    </header>

    <div class="notes-grid">
      {notes.map((n, i) => (
        <article class={`note-card reveal ${i === 0 ? 'note-card-feature' : ''}`} style={`transition-delay: ${i * 80}ms`}>
          <header class="note-card-head">
            <span class="note-num numeral">{n.num}</span>
            <span class="note-kicker serif-italic">{n.kicker}</span>
          </header>

          <h3 class="note-title">{n.title}</h3>
          <p class="note-excerpt">{n.excerpt}</p>

          <footer class="note-foot">
            <ul class="note-tags" role="list">
              {n.tags.map(t => <li>{t}</li>)}
            </ul>
            <div class="note-meta">
              <span>{n.read}</span>
              <span class="note-status">
                <span class="status-pulse"></span>
                {n.status}
              </span>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <a href="/blog" class="notes-link">
      <span>Read the field notes archive</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="7" y1="17" x2="17" y2="7"/>
        <polyline points="7,7 17,7 17,17"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .notes { background-color: var(--bg-alt); border-top: 1px solid var(--border); }

  .notes-header {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
  .notes-header .label { display: inline-flex; margin-bottom: 1rem; }
  .notes-h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.25rem, 5.5vw, 4.75rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin-top: 1.25rem;
  }
  .notes-h2 .accent { color: var(--accent); }
  .notes-circled {
    position: relative;
    display: inline-block;
    padding: 0 0.18em;
  }
  .notes-circled .serif-italic { color: var(--accent); }
  .notes-mark {
    position: absolute;
    inset: -0.18em -0.4em -0.22em -0.45em;
    color: var(--accent);
    transform: rotate(-1.5deg);
  }
  .notes-sub {
    max-width: 460px;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-2);
  }

  .notes-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .note-card {
    background: var(--bg-alt);
    padding: clamp(1.75rem, 2.5vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background-color 0.4s ease;
  }
  .note-card:hover { background: var(--bg); }
  .note-card-feature { background: var(--bg); }
  .note-card-feature .note-title {
    font-size: clamp(1.625rem, 2.5vw, 2.25rem);
  }

  .note-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px dashed var(--border);
    padding-bottom: 1rem;
    margin-bottom: 0.5rem;
  }
  .note-num {
    font-size: 1rem;
    color: var(--accent);
  }
  .note-kicker {
    font-size: 1.05rem;
    color: var(--muted);
  }

  .note-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.8vw, 1.625rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    text-wrap: balance;
  }

  .note-excerpt {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--ink-2);
    flex: 1;
  }

  .note-foot {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border);
  }
  .note-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .note-tags li {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .note-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .note-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent);
  }
  .status-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-soft);
    animation: pulseDot 2.4s ease-out infinite;
  }

  .notes-link {
    margin-top: clamp(2rem, 4vw, 3rem);
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.125rem, 1.6vw, 1.4rem);
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 0.4rem;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .notes-link:hover { color: var(--accent); border-color: var(--accent); }
  .notes-link svg { transition: transform 0.3s ease; }
  .notes-link:hover svg { transform: translate(3px, -3px); }

  @media (max-width: 1024px) {
    .notes-grid {
      grid-template-columns: 1fr 1fr;
    }
    .note-card-feature { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .notes-header { grid-template-columns: 1fr; align-items: start; }
    .notes-grid { grid-template-columns: 1fr; }
    .note-card-feature { grid-column: auto; }
  }
</style>
