<div class="hero-illustration" aria-hidden="true">
  <svg viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-svg">
    <!-- Isometric geometric composition -->
    <!-- Large rotated square -->
    <path class="draw-path" d="M240 60 L400 180 L240 300 L80 180 Z" stroke="var(--blue)" stroke-width="1.5" fill="var(--blue)" fill-opacity="0.03"/>

    <!-- Inner grid lines -->
    <path class="draw-path delay-1" d="M160 120 L320 120" stroke="var(--border)" stroke-width="1"/>
    <path class="draw-path delay-1" d="M120 180 L360 180" stroke="var(--border)" stroke-width="1"/>
    <path class="draw-path delay-1" d="M160 240 L320 240" stroke="var(--border)" stroke-width="1"/>

    <!-- Vertical axis -->
    <path class="draw-path delay-2" d="M240 60 L240 300" stroke="var(--border)" stroke-width="1"/>

    <!-- Diagonal connectors -->
    <path class="draw-path delay-2" d="M160 120 L240 180 L320 120" stroke="currentColor" stroke-width="1" opacity="0.3"/>
    <path class="draw-path delay-2" d="M160 240 L240 180 L320 240" stroke="currentColor" stroke-width="1" opacity="0.3"/>

    <!-- Accent elements -->
    <circle class="draw-circle" cx="240" cy="180" r="8" fill="var(--blue)" opacity="0.2"/>
    <circle class="draw-circle delay-1" cx="240" cy="180" r="3" fill="var(--blue)"/>

    <!-- Corner nodes -->
    <circle class="draw-circle delay-2" cx="240" cy="60" r="4" stroke="var(--blue)" stroke-width="1.5" fill="var(--bg)"/>
    <circle class="draw-circle delay-2" cx="400" cy="180" r="4" stroke="var(--blue)" stroke-width="1.5" fill="var(--bg)"/>
    <circle class="draw-circle delay-2" cx="240" cy="300" r="4" stroke="var(--blue)" stroke-width="1.5" fill="var(--bg)"/>
    <circle class="draw-circle delay-2" cx="80" cy="180" r="4" stroke="var(--blue)" stroke-width="1.5" fill="var(--bg)"/>

    <!-- Floating elements -->
    <rect class="draw-path delay-3" x="340" y="80" width="40" height="40" rx="4" stroke="var(--blue)" stroke-width="1" opacity="0.4" transform="rotate(15, 360, 100)"/>
    <rect class="draw-path delay-3" x="80" y="260" width="32" height="32" rx="4" stroke="currentColor" stroke-width="1" opacity="0.2" transform="rotate(-10, 96, 276)"/>

    <!-- Decorative dots pattern -->
    <circle cx="380" cy="260" r="2" fill="var(--blue)" opacity="0.3"/>
    <circle cx="395" cy="260" r="2" fill="var(--blue)" opacity="0.2"/>
    <circle cx="410" cy="260" r="2" fill="var(--blue)" opacity="0.1"/>
    <circle cx="380" cy="275" r="2" fill="var(--blue)" opacity="0.2"/>
    <circle cx="395" cy="275" r="2" fill="var(--blue)" opacity="0.15"/>

    <!-- X motif -->
    <g class="draw-path delay-3" opacity="0.15">
      <line x1="100" y1="320" x2="140" y2="360" stroke="var(--blue)" stroke-width="2"/>
      <line x1="140" y1="320" x2="100" y2="360" stroke="var(--blue)" stroke-width="2"/>
    </g>

    <!-- Bottom floating bar -->
    <rect class="draw-path delay-3" x="200" y="340" width="80" height="6" rx="3" fill="var(--blue)" opacity="0.15"/>
  </svg>
</div>

<style>
  .hero-illustration {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1;
  }

  .hero-svg {
    width: 100%;
    height: 100%;
    color: var(--text-muted);
  }

  /* Path draw animation */
  .draw-path {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: drawPath 1.5s ease-out forwards;
  }

  .draw-circle {
    opacity: 0;
    animation: fadeInScale 0.4s ease-out forwards;
    animation-delay: 1s;
  }

  .delay-1 { animation-delay: 0.3s; }
  .delay-2 { animation-delay: 0.6s; }
  .delay-3 { animation-delay: 0.9s; }

  .draw-circle.delay-1 { animation-delay: 1.2s; }
  .draw-circle.delay-2 { animation-delay: 1.4s; }

  @keyframes drawPath {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.5);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 768px) {
    .hero-illustration {
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>
