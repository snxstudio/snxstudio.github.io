---
// Hand-drawn project sketch glyphs. Pass `name` matching one of the cases.
// Renders inside a small "blueprint" frame on the work cards.

interface Props {
  name: string;
  class?: string;
}
const { name, class: className = '' } = Astro.props;
---

<span class:list={['project-sketch', className]} aria-hidden="true">
  <svg viewBox="0 0 200 140" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <filter id={`rough-${name}`} x="-5%" y="-5%" width="110%" height="110%">
        <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="2" seed="5"/>
        <feDisplacementMap in="SourceGraphic" scale="1.1"/>
      </filter>
    </defs>

    <g filter={`url(#rough-${name})`} stroke="currentColor" fill="none"
       stroke-linecap="round" stroke-linejoin="round" stroke-width="2">

      {name === 'logistics' && (
        <g>
          {/* shipping container */}
          <path d="M 26 70 L 96 70 L 96 110 L 26 110 Z"/>
          <path d="M 38 70 L 38 110 M 50 70 L 50 110 M 62 70 L 62 110 M 74 70 L 74 110 M 86 70 L 86 110"/>
          {/* second container, on top */}
          <path d="M 60 38 L 130 38 L 130 70 L 60 70 Z"/>
          <path d="M 72 38 L 72 70 M 84 38 L 84 70 M 96 38 L 96 70 M 108 38 L 108 70 M 120 38 L 120 70"/>
          {/* AI spark */}
          <circle cx="158" cy="50" r="14"/>
          <path d="M 158 36 L 158 28 M 158 64 L 158 72 M 144 50 L 136 50 M 172 50 L 180 50 M 148 40 L 142 34 M 168 60 L 174 66 M 168 40 L 174 34 M 148 60 L 142 66"/>
          <circle cx="158" cy="50" r="3" fill="currentColor"/>
          {/* dashed dock line */}
          <path d="M 18 118 L 188 118" stroke-dasharray="2 4"/>
        </g>
      )}

      {name === 'meter' && (
        <g>
          {/* meter face */}
          <circle cx="70" cy="70" r="44"/>
          <circle cx="70" cy="70" r="36"/>
          {/* tick marks */}
          <path d="M 70 30 L 70 36 M 70 104 L 70 110 M 30 70 L 36 70 M 104 70 L 110 70 M 42 42 L 46 46 M 94 94 L 98 98 M 98 42 L 94 46 M 42 98 L 46 94"/>
          {/* needle pointing to "max" */}
          <path d="M 70 70 L 96 50" stroke-width="3"/>
          <circle cx="70" cy="70" r="4" fill="currentColor"/>
          {/* lightning bolt */}
          <path d="M 144 30 L 130 70 L 148 70 L 134 110 L 174 60 L 152 60 L 168 30 Z"/>
        </g>
      )}

      {name === 'searoute' && (
        <g>
          {/* world map fragments (continents) */}
          <path d="M 18 50 C 28 44, 44 48, 56 56 C 64 62, 70 68, 64 78 C 56 88, 38 86, 28 78 C 18 70, 14 58, 18 50 Z"/>
          <path d="M 110 30 C 124 26, 142 32, 154 42 C 162 50, 158 60, 148 64 C 134 68, 118 62, 110 52 C 104 44, 102 36, 110 30 Z"/>
          <path d="M 130 90 C 144 84, 160 88, 172 96 C 178 104, 174 114, 162 116 C 148 118, 134 110, 128 100 C 124 96, 124 92, 130 90 Z"/>
          {/* the route */}
          <path d="M 40 70 C 70 56, 100 100, 130 70 C 150 50, 160 92, 175 102" stroke-dasharray="3 4" stroke-width="2.4"/>
          {/* ship marker */}
          <circle cx="100" cy="78" r="5" fill="currentColor"/>
          {/* compass mini */}
          <circle cx="30" cy="118" r="9"/>
          <path d="M 30 110 L 30 126 M 22 118 L 38 118"/>
        </g>
      )}

      {name === 'prompt' && (
        <g>
          {/* scroll / parchment */}
          <path d="M 36 26 C 36 22, 40 18, 44 18 L 138 18 C 142 18, 146 22, 146 26 L 146 110 C 146 114, 142 118, 138 118 L 44 118 C 40 118, 36 114, 36 110 Z"/>
          {/* prompt lines */}
          <path d="M 50 38 L 130 38" stroke-width="2.6"/>
          <path d="M 50 50 L 110 50" stroke-dasharray="3 3"/>
          <path d="M 50 62 L 124 62"/>
          <path d="M 50 74 L 96 74" stroke-dasharray="3 3"/>
          <path d="M 50 86 L 130 86"/>
          <path d="M 50 98 L 102 98" stroke-dasharray="3 3"/>
          {/* version tag */}
          <path d="M 156 60 L 178 60 L 184 70 L 178 80 L 156 80 Z"/>
          <text x="158" y="74" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" stroke="none">v01</text>
          {/* connecting tab */}
          <path d="M 146 70 L 156 70" stroke-dasharray="2 3"/>
        </g>
      )}

      {name === 'agritech' && (
        <g>
          {/* field rows */}
          <path d="M 18 110 C 60 104, 140 116, 188 108"/>
          <path d="M 18 122 C 60 116, 140 128, 188 120"/>
          {/* plant 1 */}
          <path d="M 60 110 C 60 92, 56 80, 60 70"/>
          <path d="M 60 88 C 52 84, 46 80, 44 72 C 50 70, 56 76, 60 84 Z"/>
          <path d="M 60 78 C 68 76, 74 70, 76 60 C 70 60, 64 66, 60 74 Z"/>
          {/* plant 2 — bigger */}
          <path d="M 100 110 C 100 86, 94 70, 100 56"/>
          <path d="M 100 80 C 88 78, 80 70, 76 60 C 84 58, 94 64, 100 74 Z"/>
          <path d="M 100 70 C 112 66, 118 60, 120 50 C 110 50, 102 56, 100 66 Z"/>
          {/* sensor antenna */}
          <path d="M 150 110 L 150 60"/>
          <circle cx="150" cy="56" r="6"/>
          <path d="M 142 50 C 144 44, 152 42, 158 46 M 138 42 C 142 32, 156 30, 166 38" stroke-dasharray="2 2"/>
          <rect x="146" y="106" width="8" height="14"/>
        </g>
      )}

      {name === 'lastmile' && (
        <g>
          {/* parcel */}
          <path d="M 28 60 L 70 60 L 70 102 L 28 102 Z"/>
          <path d="M 28 78 L 70 78"/>
          <path d="M 49 60 L 49 102" stroke-dasharray="3 3"/>
          {/* scooter */}
          <circle cx="120" cy="100" r="14"/>
          <circle cx="170" cy="100" r="14"/>
          <path d="M 134 100 L 156 100"/>
          <path d="M 144 100 L 138 78 L 116 78 M 138 78 L 152 60 L 168 60 L 174 70"/>
          <path d="M 174 70 L 174 88"/>
          <path d="M 152 60 L 148 50 L 154 50"/>
          {/* motion lines */}
          <path d="M 88 86 L 102 86 M 84 96 L 100 96 M 88 106 L 102 106" stroke-dasharray="2 2"/>
        </g>
      )}

    </g>
  </svg>
</span>

<style>
  .project-sketch {
    display: inline-block;
    width: 100%;
    height: 100%;
    color: var(--ink);
    line-height: 0;
  }
  .project-sketch svg { width: 100%; height: 100%; display: block; }
</style>
