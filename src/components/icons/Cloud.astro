---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<svg class={className} width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Network nodes -->
  <circle cx="24" cy="10" r="4" stroke="var(--blue)" stroke-width="2" fill="var(--blue)" fill-opacity="0.1"/>
  <circle cx="10" cy="22" r="3" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="38" cy="20" r="3" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="14" cy="36" r="3" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="34" cy="36" r="3" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="24" cy="28" r="4" stroke="var(--blue)" stroke-width="2" fill="var(--blue)" fill-opacity="0.1"/>
  <!-- Connections -->
  <line x1="21" y1="13" x2="12" y2="20" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
  <line x1="27" y1="13" x2="36" y2="18" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
  <line x1="24" y1="14" x2="24" y2="24" stroke="var(--blue)" stroke-width="1.5" opacity="0.6"/>
  <line x1="12" y1="24" x2="21" y2="27" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
  <line x1="36" y1="22" x2="27" y2="27" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
  <line x1="22" y1="31" x2="16" y2="34" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
  <line x1="27" y1="31" x2="32" y2="34" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
  <line x1="17" y1="36" x2="31" y2="36" stroke="currentColor" stroke-width="1" opacity="0.2" stroke-dasharray="2 2"/>
</svg>
