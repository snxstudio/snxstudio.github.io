---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<svg class={className} width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Browser frame -->
  <rect x="4" y="8" width="40" height="32" rx="3" stroke="currentColor" stroke-width="2"/>
  <line x1="4" y1="16" x2="44" y2="16" stroke="currentColor" stroke-width="2"/>
  <!-- Window dots -->
  <circle cx="10" cy="12" r="1.5" fill="var(--blue)"/>
  <circle cx="15" cy="12" r="1.5" fill="currentColor" opacity="0.3"/>
  <circle cx="20" cy="12" r="1.5" fill="currentColor" opacity="0.3"/>
  <!-- Asymmetric grid inside -->
  <rect x="8" y="20" width="18" height="16" rx="1" stroke="var(--blue)" stroke-width="1.5" fill="var(--blue)" fill-opacity="0.08"/>
  <rect x="30" y="20" width="10" height="7" rx="1" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
  <rect x="30" y="31" width="10" height="5" rx="1" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
</svg>
