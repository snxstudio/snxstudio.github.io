---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<svg class={className} width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Central chip -->
  <rect x="16" y="16" width="16" height="16" rx="2" stroke="var(--blue)" stroke-width="2" fill="var(--blue)" fill-opacity="0.08"/>
  <rect x="20" y="20" width="8" height="8" rx="1" stroke="var(--blue)" stroke-width="1.5"/>
  <!-- Connection pins -->
  <!-- Top -->
  <line x1="21" y1="16" x2="21" y2="10" stroke="currentColor" stroke-width="1.5"/>
  <line x1="27" y1="16" x2="27" y2="10" stroke="currentColor" stroke-width="1.5"/>
  <!-- Bottom -->
  <line x1="21" y1="32" x2="21" y2="38" stroke="currentColor" stroke-width="1.5"/>
  <line x1="27" y1="32" x2="27" y2="38" stroke="currentColor" stroke-width="1.5"/>
  <!-- Left -->
  <line x1="16" y1="21" x2="10" y2="21" stroke="currentColor" stroke-width="1.5"/>
  <line x1="16" y1="27" x2="10" y2="27" stroke="currentColor" stroke-width="1.5"/>
  <!-- Right -->
  <line x1="32" y1="21" x2="38" y2="21" stroke="currentColor" stroke-width="1.5"/>
  <line x1="32" y1="27" x2="38" y2="27" stroke="currentColor" stroke-width="1.5"/>
  <!-- Radiating dots -->
  <circle cx="21" cy="7" r="2" fill="currentColor" opacity="0.4"/>
  <circle cx="27" cy="7" r="2" fill="currentColor" opacity="0.4"/>
  <circle cx="21" cy="41" r="2" fill="currentColor" opacity="0.4"/>
  <circle cx="27" cy="41" r="2" fill="currentColor" opacity="0.4"/>
  <circle cx="7" cy="21" r="2" fill="currentColor" opacity="0.4"/>
  <circle cx="7" cy="27" r="2" fill="currentColor" opacity="0.4"/>
  <circle cx="41" cy="21" r="2" fill="currentColor" opacity="0.4"/>
  <circle cx="41" cy="27" r="2" fill="currentColor" opacity="0.4"/>
</svg>
