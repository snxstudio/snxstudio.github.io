---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<svg class={className} width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Back layer -->
  <rect x="10" y="6" width="24" height="30" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
  <!-- Middle layer -->
  <rect x="14" y="10" width="24" height="30" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.5" fill="var(--bg)"/>
  <!-- Front layer -->
  <rect x="18" y="14" width="24" height="30" rx="2" stroke="var(--blue)" stroke-width="2" fill="var(--blue)" fill-opacity="0.06"/>
  <!-- Content lines -->
  <line x1="23" y1="21" x2="37" y2="21" stroke="var(--blue)" stroke-width="1.5" opacity="0.5"/>
  <line x1="23" y1="27" x2="34" y2="27" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
  <line x1="23" y1="33" x2="31" y2="33" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
  <!-- Cursor -->
  <path d="M8 36 L8 44 L11 41 L14 46 L16 45 L13 40 L17 40 Z" fill="var(--blue)" opacity="0.8"/>
</svg>
