---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<svg class={className} width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Neural network nodes -->
  <!-- Input layer -->
  <circle cx="10" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="10" cy="24" r="3" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="10" cy="34" r="3" stroke="currentColor" stroke-width="1.5"/>
  <!-- Hidden layer -->
  <circle cx="24" cy="12" r="3" stroke="var(--blue)" stroke-width="1.5"/>
  <circle cx="24" cy="24" r="3.5" stroke="var(--blue)" stroke-width="2" fill="var(--blue)" fill-opacity="0.15"/>
  <circle cx="24" cy="36" r="3" stroke="var(--blue)" stroke-width="1.5"/>
  <!-- Output layer -->
  <circle cx="38" cy="18" r="3" stroke="currentColor" stroke-width="1.5"/>
  <circle cx="38" cy="30" r="3" stroke="currentColor" stroke-width="1.5"/>
  <!-- Connections -->
  <line x1="13" y1="14" x2="21" y2="12" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="13" y1="14" x2="21" y2="24" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="13" y1="24" x2="21" y2="12" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="13" y1="24" x2="21" y2="24" stroke="var(--blue)" stroke-width="1.5" opacity="0.6"/>
  <line x1="13" y1="24" x2="21" y2="36" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="13" y1="34" x2="21" y2="24" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="13" y1="34" x2="21" y2="36" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="27" y1="12" x2="35" y2="18" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <line x1="27" y1="24" x2="35" y2="18" stroke="var(--blue)" stroke-width="1.5" opacity="0.6"/>
  <line x1="27" y1="24" x2="35" y2="30" stroke="var(--blue)" stroke-width="1.5" opacity="0.6"/>
  <line x1="27" y1="36" x2="35" y2="30" stroke="currentColor" stroke-width="1" opacity="0.4"/>
</svg>
