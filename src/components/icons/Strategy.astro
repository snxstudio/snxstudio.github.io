---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<svg class={className} width={size} height={size} viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Compass outer ring -->
  <circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
  <circle cx="24" cy="24" r="12" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
  <!-- Cardinal ticks -->
  <line x1="24" y1="4" x2="24" y2="8" stroke="currentColor" stroke-width="1.5"/>
  <line x1="24" y1="40" x2="24" y2="44" stroke="currentColor" stroke-width="1.5"/>
  <line x1="4" y1="24" x2="8" y2="24" stroke="currentColor" stroke-width="1.5"/>
  <line x1="40" y1="24" x2="44" y2="24" stroke="currentColor" stroke-width="1.5"/>
  <!-- Compass needle - north -->
  <polygon points="24,10 21,24 27,24" fill="var(--blue)" opacity="0.8"/>
  <!-- Compass needle - south -->
  <polygon points="24,38 21,24 27,24" fill="currentColor" opacity="0.2"/>
  <!-- Center dot -->
  <circle cx="24" cy="24" r="2.5" fill="var(--blue)"/>
  <!-- Directional accent -->
  <line x1="24" y1="24" x2="34" y2="16" stroke="var(--blue)" stroke-width="1.5" opacity="0.4" stroke-dasharray="2 2"/>
</svg>
