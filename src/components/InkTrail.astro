---
// Pen-quality cursor ink with intelligent states.
//
// Trail layers:
//   1. Bleed halo  — thick, very low alpha, --accent-deep
//   2. Wet stroke  — calligraphic Catmull-Rom curve, --accent
//   3. Splatter    — droplets emit at high speed and on left-click
//   4. Stamp       — wax-seal blob + dashed rubber-stamp ring on right-click / long-press
//
// Cursor states:
//   default   — idle pen
//   moving    — eased follow, tilts with motion direction
//   hovering  — over <a>/<button>/[data-grab]: pen tilts up, accent ring
//   writing   — over input/textarea: pen angles to writing position
//   pressing  — left mousedown: small ink-dot pops under nib
//   idle      — no motion for 800ms: small ink-droplet pulses below nib
//
// Right-click is NOT blocked. The native context menu still appears.
---

<canvas id="ink-trail" aria-hidden="true"></canvas>

<div id="ink-cursor" aria-hidden="true">
  <span class="ink-cursor-dot"></span>
  <span class="ink-cursor-ring"></span>
  <span class="ink-cursor-label" data-default="·" data-hover="click" data-write="type">·</span>
</div>

<style>
  #ink-trail {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 9994;
    mix-blend-mode: multiply;
  }
  :global(.dark) #ink-trail { mix-blend-mode: screen; }

  #ink-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 14px;
    height: 14px;
    pointer-events: none;
    z-index: 9999;
    transform: translate3d(-100px, -100px, 0);
    will-change: transform;
    transition: opacity 0.25s ease;
    opacity: 0;
  }
  #ink-cursor.active { opacity: 1; }

  /* Inner ink-blot — the actual cursor anchor */
  .ink-cursor-dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    transform: translate(-50%, -50%) scale(1);
    transition:
      width 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      height 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      background-color 0.2s ease,
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 1px 2px rgba(0,0,0,0.18);
  }

  /* Outer ring — only when over interactive elements */
  .ink-cursor-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 44px;
    height: 44px;
    border: 1.4px dashed var(--accent);
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0.4);
    opacity: 0;
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      border-radius 0.25s ease,
      border-style 0.25s ease;
  }

  /* Optional small label inside the ring */
  .ink-cursor-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.25s ease 0.05s;
    pointer-events: none;
    white-space: nowrap;
  }

  /* HOVER state — over <a>/<button>/[data-grab] */
  #ink-cursor.hovering .ink-cursor-dot {
    width: 4px;
    height: 4px;
    background: var(--ink);
  }
  #ink-cursor.hovering .ink-cursor-ring {
    opacity: 0.95;
    transform: translate(-50%, -50%) scale(1);
    animation: cursorRingSpin 4s linear infinite;
  }
  #ink-cursor.hovering .ink-cursor-label::before {
    content: attr(data-hover);
    opacity: 1;
  }
  #ink-cursor.hovering .ink-cursor-label { opacity: 0; }
  #ink-cursor.hovering .ink-cursor-label::after { display: none; }

  /* WRITING — over inputs */
  #ink-cursor.writing .ink-cursor-dot {
    width: 2px;
    height: 16px;
    border-radius: 1px;
    background: var(--ink);
    animation: cursorBlink 1s steps(2) infinite;
  }
  #ink-cursor.writing .ink-cursor-ring {
    opacity: 0.45;
    transform: translate(-50%, -50%) scale(0.7);
    border-radius: 4px;
    border-style: solid;
    border-width: 1px;
    animation: none;
  }

  /* PRESSING — left mouse down */
  #ink-cursor.pressing .ink-cursor-dot {
    transform: translate(-50%, -50%) scale(1.6);
    background: var(--accent-deep);
  }
  #ink-cursor.pressing .ink-cursor-ring {
    opacity: 1;
    transform: translate(-50%, -50%) scale(0.7);
    border-color: var(--accent-deep);
    border-style: solid;
  }

  /* IDLE — gentle pulse */
  #ink-cursor.idle .ink-cursor-dot {
    animation: cursorPulse 2s ease-in-out infinite;
  }

  @keyframes cursorRingSpin {
    to { transform: translate(-50%, -50%) scale(1) rotate(360deg); }
  }
  @keyframes cursorPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1);   opacity: 1; }
    50%      { transform: translate(-50%, -50%) scale(1.4); opacity: 0.6; }
  }
  @keyframes cursorBlink {
    50% { opacity: 0; }
  }

  /* Hide system cursor only when ours is active */
  :global(html.has-ink-cursor),
  :global(html.has-ink-cursor *) {
    cursor: none !important;
  }

  @media (hover: none), (prefers-reduced-motion: reduce) {
    #ink-trail, #ink-cursor { display: none; }
  }
</style>

<script>
  const canvas = document.getElementById('ink-trail') as HTMLCanvasElement | null;
  const cursorEl = document.getElementById('ink-cursor') as HTMLDivElement | null;
  const supportsHover = window.matchMedia('(hover: hover)').matches;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && cursorEl && supportsHover && !reduce) {
    document.documentElement.classList.add('has-ink-cursor');

    const ctx = canvas.getContext('2d')!;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = window.innerWidth * dpr;
      canvas!.height = window.innerHeight * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    function readColors() {
      const styles = getComputedStyle(document.documentElement);
      const ink = (styles.getPropertyValue('--accent').trim() || '#C9311E');
      const inkDeep = (styles.getPropertyValue('--accent-deep').trim() || '#9D2818');
      const pen = (styles.getPropertyValue('--ink').trim() || '#14131A');
      return { ink, inkDeep, pen };
    }

    type Pt = { x: number; y: number; t: number; w: number; };
    type Splat = { x: number; y: number; r: number; born: number; life: number; vx: number; vy: number; };
    type Stamp = { x: number; y: number; born: number; life: number; rot: number; r: number; seed: number; };

    const pts: Pt[] = [];
    const splats: Splat[] = [];
    const stamps: Stamp[] = [];
    const MAX_AGE = 1700;
    const MAX_PTS = 80;
    let lastX = -1, lastY = -1, lastT = 0;
    let lastEmit = 0;

    let cx = -100, cy = -100;
    let tx = -100, ty = -100;
    const CURSOR_HALF = 7;

    let idleTimer: number | null = null;
    let pressTimer: number | null = null;
    let pressX = 0, pressY = 0;

    function setIdleSoon() {
      if (idleTimer) window.clearTimeout(idleTimer);
      cursorEl!.classList.remove('idle');
      idleTimer = window.setTimeout(() => cursorEl!.classList.add('idle'), 900);
    }

    function emitSplat(x: number, y: number, speed: number) {
      const count = Math.min(4, Math.floor(speed * 0.06));
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist = 4 + Math.random() * 12;
        splats.push({
          x: x + Math.cos(angle) * dist,
          y: y + Math.sin(angle) * dist,
          r: 0.6 + Math.random() * 1.6,
          born: performance.now(),
          life: 600 + Math.random() * 600,
          vx: Math.cos(angle) * (0.4 + Math.random() * 0.6),
          vy: Math.sin(angle) * (0.4 + Math.random() * 0.6),
        });
      }
    }

    function clickBurst(x: number, y: number) {
      for (let i = 0; i < 12; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 0.6 + Math.random() * 2.2;
        splats.push({
          x, y,
          r: 0.8 + Math.random() * 2.2,
          born: performance.now(),
          life: 700 + Math.random() * 700,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
        });
      }
    }

    function emitStamp(x: number, y: number) {
      const r = 16 + Math.random() * 4;
      stamps.push({
        x, y,
        born: performance.now(),
        life: 4500,
        rot: (Math.random() - 0.5) * 0.5,
        r,
        seed: Math.random() * Math.PI * 2,
      });
      // surrounding splatter for realism
      for (let i = 0; i < 8; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist = r + 4 + Math.random() * 16;
        splats.push({
          x: x + Math.cos(angle) * dist,
          y: y + Math.sin(angle) * dist,
          r: 0.6 + Math.random() * 1.4,
          born: performance.now(),
          life: 1400 + Math.random() * 800,
          vx: Math.cos(angle) * 0.18,
          vy: Math.sin(angle) * 0.18,
        });
      }
    }

    function updateHoverState(x: number, y: number) {
      const el = document.elementFromPoint(x, y) as HTMLElement | null;
      if (!el) return;
      const interactive = el.closest('a, button, [data-grab], [role="button"], summary, label[for]');
      const writable = el.closest('input:not([type="checkbox"]):not([type="radio"]):not([type="submit"]):not([type="button"]), textarea, select, [contenteditable="true"]');
      cursorEl!.classList.toggle('hovering', !!interactive && !writable);
      cursorEl!.classList.toggle('writing', !!writable);
    }

    window.addEventListener('pointermove', (e) => {
      if ((e as PointerEvent).pointerType === 'touch') return;
      tx = e.clientX;
      ty = e.clientY;
      cursorEl!.classList.add('active');
      setIdleSoon();
      updateHoverState(e.clientX, e.clientY);

      // cancel long-press if pointer drifts more than 8px
      if (pressTimer && (Math.abs(e.clientX - pressX) > 8 || Math.abs(e.clientY - pressY) > 8)) {
        window.clearTimeout(pressTimer);
        pressTimer = null;
      }

      const now = performance.now();
      if (now - lastEmit < 6) return;
      lastEmit = now;

      let speed = 0;
      if (lastX >= 0) {
        const dx = e.clientX - lastX;
        const dy = e.clientY - lastY;
        const dt = Math.max(8, now - lastT);
        speed = Math.hypot(dx, dy) / dt * 16;
      }
      lastX = e.clientX;
      lastY = e.clientY;
      lastT = now;

      const w = Math.max(1.4, 9 - Math.min(speed, 60) * 0.13);
      pts.push({ x: e.clientX, y: e.clientY, t: now, w });
      if (pts.length > MAX_PTS) pts.splice(0, pts.length - MAX_PTS);

      if (speed > 26) emitSplat(e.clientX, e.clientY, speed);
    }, { passive: true });

    window.addEventListener('pointerleave', () => cursorEl!.classList.remove('active', 'idle'));
    window.addEventListener('pointerenter', () => cursorEl!.classList.add('active'));

    window.addEventListener('pointerdown', (e) => {
      const ev = e as PointerEvent;
      if (ev.pointerType === 'touch') return;

      // Right-click → stamp (don't block native context menu, contextmenu handler also fires)
      if (ev.button === 2) {
        // contextmenu handler will emit; nothing to do here
        return;
      }

      // Middle click → ignore for now
      if (ev.button !== 0) return;

      // Left click → small splatter burst + small press dot + arm long-press
      cursorEl!.classList.add('pressing');
      clickBurst(ev.clientX, ev.clientY);

      pressX = ev.clientX;
      pressY = ev.clientY;
      if (pressTimer) window.clearTimeout(pressTimer);
      pressTimer = window.setTimeout(() => {
        emitStamp(pressX, pressY);
        pressTimer = null;
      }, 550);
    });

    window.addEventListener('pointerup', () => {
      cursorEl!.classList.remove('pressing');
      if (pressTimer) { window.clearTimeout(pressTimer); pressTimer = null; }
    });
    window.addEventListener('pointercancel', () => {
      cursorEl!.classList.remove('pressing');
      if (pressTimer) { window.clearTimeout(pressTimer); pressTimer = null; }
    });

    // Right-click → wax-seal stamp. DO NOT preventDefault — keep native context menu.
    window.addEventListener('contextmenu', (e) => {
      emitStamp(e.clientX, e.clientY);
    });

    function strokePath(pass: 'bleed' | 'wet') {
      const now = performance.now();
      if (pts.length < 2) return;
      const { ink, inkDeep } = readColors();
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.strokeStyle = pass === 'bleed' ? inkDeep : ink;

      for (let i = 1; i < pts.length; i++) {
        const p0 = pts[i - 2] || pts[i - 1];
        const p1 = pts[i - 1];
        const p2 = pts[i];
        const p3 = pts[i + 1] || pts[i];

        const age = (now - p2.t) / MAX_AGE;
        if (age >= 1) continue;
        const alpha = 1 - age;

        const c1x = p1.x + (p2.x - p0.x) / 6;
        const c1y = p1.y + (p2.y - p0.y) / 6;
        const c2x = p2.x - (p3.x - p1.x) / 6;
        const c2y = p2.y - (p3.y - p1.y) / 6;

        const baseWidth = (p1.w + p2.w) / 2;
        const widthMul = pass === 'bleed' ? 2.6 : 1;
        const alphaMul = pass === 'bleed' ? 0.18 : 0.92;

        ctx.globalAlpha = alpha * alphaMul;
        ctx.lineWidth = Math.max(0.4, baseWidth * widthMul * (1 - age * 0.7));
        ctx.beginPath();
        ctx.moveTo(p1.x, p1.y);
        ctx.bezierCurveTo(c1x, c1y, c2x, c2y, p2.x, p2.y);
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    }

    function drawSplats() {
      const now = performance.now();
      const { ink } = readColors();
      ctx.fillStyle = ink;
      for (let i = splats.length - 1; i >= 0; i--) {
        const s = splats[i];
        const age = (now - s.born) / s.life;
        if (age >= 1) { splats.splice(i, 1); continue; }
        s.x += s.vx;
        s.y += s.vy;
        s.vx *= 0.94;
        s.vy *= 0.94;
        ctx.globalAlpha = (1 - age) * 0.85;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r * (1 - age * 0.3), 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }

    function drawStamps() {
      const now = performance.now();
      const { ink, inkDeep } = readColors();

      for (let i = stamps.length - 1; i >= 0; i--) {
        const s = stamps[i];
        const age = (now - s.born) / s.life;
        if (age >= 1) { stamps.splice(i, 1); continue; }

        const fadeIn = Math.min(1, age / 0.06);
        const fadeOut = age > 0.78 ? 1 - (age - 0.78) / 0.22 : 1;
        const alpha = fadeIn * fadeOut;

        ctx.save();
        ctx.translate(s.x, s.y);
        ctx.rotate(s.rot);

        // Wax-blob — irregular polygon
        ctx.globalAlpha = alpha * 0.88;
        ctx.fillStyle = inkDeep;
        ctx.beginPath();
        const segs = 16;
        for (let k = 0; k <= segs; k++) {
          const a = (k / segs) * Math.PI * 2;
          const wob = 1 + Math.sin(a * 3 + s.seed) * 0.18 + Math.cos(a * 5 - s.seed) * 0.08;
          const rx = Math.cos(a) * s.r * wob;
          const ry = Math.sin(a) * s.r * wob;
          if (k === 0) ctx.moveTo(rx, ry); else ctx.lineTo(rx, ry);
        }
        ctx.closePath();
        ctx.fill();

        // Inner highlight (lighter ink) for depth
        ctx.globalAlpha = alpha * 0.55;
        ctx.fillStyle = ink;
        ctx.beginPath();
        ctx.arc(-s.r * 0.18, -s.r * 0.22, s.r * 0.45, 0, Math.PI * 2);
        ctx.fill();

        // Rubber-stamp dashed ring
        ctx.globalAlpha = alpha * 0.6;
        ctx.strokeStyle = inkDeep;
        ctx.lineWidth = 1.4;
        ctx.setLineDash([4, 4]);
        ctx.beginPath();
        ctx.arc(0, 0, s.r + 9, 0, Math.PI * 2);
        ctx.stroke();
        ctx.setLineDash([]);

        // Tiny "SNX" mono mark in the center
        ctx.globalAlpha = alpha * 0.85;
        ctx.fillStyle = '#FFF';
        ctx.font = '600 8px JetBrains Mono, ui-monospace, monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('SNX', 0, 1);

        ctx.restore();
      }
      ctx.globalAlpha = 1;
    }

    function frame() {
      ctx.clearRect(0, 0, canvas!.width / dpr, canvas!.height / dpr);

      const now = performance.now();
      while (pts.length && now - pts[0].t > MAX_AGE) pts.shift();

      drawStamps();    // stamps under everything
      strokePath('bleed');
      strokePath('wet');
      drawSplats();

      // Cursor easing — fast follow so the dot feels precise
      cx += (tx - cx) * 0.55;
      cy += (ty - cy) * 0.55;
      cursorEl!.style.transform = `translate3d(${cx - CURSOR_HALF}px, ${cy - CURSOR_HALF}px, 0)`;

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }
</script>
