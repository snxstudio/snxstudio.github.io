---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Mark from '../components/Marks.astro';

const suggestions = [
  { num: '01', label: 'Studio (about)', href: '/about' },
  { num: '02', label: 'Selected work', href: '/work' },
  { num: '03', label: 'Services', href: '/services' },
  { num: '04', label: 'Open source', href: '/opensource' },
  { num: '05', label: 'Field notes', href: '/blog' },
  { num: '06', label: 'Contact', href: '/contact' },
];
---

<Layout title="404 — Page not found" description="That page seems to have walked off. Pick a different door.">
  <Nav />
  <main class="not-found">
    <!-- Decorative paper rules -->
    <div class="nf-bg" aria-hidden="true">
      <svg viewBox="0 0 1440 900" preserveAspectRatio="none">
        <g stroke="var(--ink)" stroke-width="0.6" opacity="0.10">
          <line x1="0" y1="180" x2="1440" y2="180" stroke-dasharray="3 6"/>
          <line x1="0" y1="360" x2="1440" y2="360" stroke-dasharray="3 6"/>
          <line x1="0" y1="540" x2="1440" y2="540" stroke-dasharray="3 6"/>
          <line x1="0" y1="720" x2="1440" y2="720" stroke-dasharray="3 6"/>
        </g>
      </svg>
    </div>

    <section class="nf-section">
      <div class="container-wide nf-grid">
        <!-- Left: ransom-note title + suggestions -->
        <div class="nf-left">
          <span class="tape tape-tilt-l">— filed under: missing —</span>

          <h1 class="nf-title">
            <span class="nf-word nf-w1">This</span>
            <span class="nf-word nf-w2 serif-italic">page</span>
            <span class="nf-word nf-w3">has</span>
            <span class="nf-word nf-w4">walked</span>
            <span class="nf-word nf-w5 nf-w-circled">
              off<span class="nf-w-mark"><Mark name="ink-circle" /></span>
            </span>
            <span class="nf-word nf-w6">.</span>
          </h1>

          <p class="nf-lede serif-italic">
            Either the URL is wrong, the page was retired, or some other small
            indignity has happened. Pick a different door — the studio is still
            very much in.
          </p>

          <ol class="nf-suggestions" role="list">
            {suggestions.map((s) => (
              <li>
                <a href={s.href} class="nf-suggestion">
                  <span class="nf-sugg-num numeral">{s.num}</span>
                  <span class="nf-sugg-label">{s.label}</span>
                  <Mark name="arrow-r" class="nf-sugg-arrow" />
                </a>
              </li>
            ))}
          </ol>

          <div class="nf-actions">
            <a href="/" class="btn-primary">
              Back to the front desk
              <Mark name="arrow-r" class="btn-mark" />
            </a>
            <a href="/contact" class="btn-ghost">
              Tell us what you were looking for
            </a>
          </div>
        </div>

        <!-- Right: giant stamped 404 -->
        <aside class="nf-right" aria-hidden="true">
          <div class="nf-stamp">
            <svg viewBox="0 0 320 320" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <filter id="stamp-rough" x="-5%" y="-5%" width="110%" height="110%">
                  <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="2" seed="3"/>
                  <feDisplacementMap in="SourceGraphic" scale="2"/>
                </filter>
              </defs>
              <g filter="url(#stamp-rough)" stroke="var(--accent)" fill="none"
                 stroke-linecap="round" stroke-linejoin="round">
                <!-- Outer rough rectangle stamp -->
                <rect x="14" y="14" width="292" height="292" rx="6" stroke-width="3.5"/>
                <rect x="22" y="22" width="276" height="276" rx="4" stroke-width="1.4" opacity="0.55"/>

                <!-- Header arc text mimic -->
                <text x="160" y="58" text-anchor="middle"
                      font-family="JetBrains Mono, monospace"
                      font-size="14" letter-spacing="6"
                      fill="var(--accent)" stroke="none">PAGE · NOT · FOUND</text>

                <!-- Footer text -->
                <text x="160" y="290" text-anchor="middle"
                      font-family="JetBrains Mono, monospace"
                      font-size="11" letter-spacing="4"
                      fill="var(--accent)" stroke="none">SNX · STUDIO · ARCHIVE</text>

                <!-- Divider rules -->
                <line x1="32" y1="78" x2="288" y2="78" stroke-width="1.2"/>
                <line x1="32" y1="262" x2="288" y2="262" stroke-width="1.2"/>
              </g>

              <!-- Big 404 numerals — display font, slight tilt -->
              <g transform="translate(160 180) rotate(-3)">
                <text text-anchor="middle"
                      font-family="Syne, sans-serif" font-weight="700"
                      font-size="160" letter-spacing="-8"
                      fill="var(--accent)">404</text>
              </g>

              <!-- Cancellation strikes -->
              <g stroke="var(--accent-deep)" stroke-width="2.5" stroke-linecap="round" opacity="0.55">
                <line x1="44" y1="106" x2="276" y2="262"/>
                <line x1="276" y1="106" x2="44" y2="262"/>
              </g>
            </svg>
          </div>

          <span class="nf-stamp-note serif-italic">— rejected by the archive —</span>
        </aside>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .not-found {
    position: relative;
    padding-top: calc(78px + clamp(3rem, 6vw, 6rem));
    padding-bottom: clamp(4rem, 8vw, 7rem);
    overflow: hidden;
  }

  .nf-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .nf-bg svg { width: 100%; height: 100%; }

  .nf-section { position: relative; z-index: 2; }
  .nf-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  /* LEFT */
  .nf-left { display: flex; flex-direction: column; gap: 1.5rem; }

  .nf-title {
    margin: 0.5rem 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 6rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.32em;
  }
  .nf-word {
    display: inline-block;
    transform-origin: center;
  }
  /* Ransom-note alternating tilts and weights */
  .nf-w1 { transform: rotate(-1.5deg); }
  .nf-w2 {
    color: var(--accent);
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 1.15em;
    transform: rotate(2deg) translateY(0.05em);
  }
  .nf-w3 {
    transform: rotate(-1deg);
    background: var(--ink);
    color: var(--bg);
    padding: 0 0.2em;
  }
  .nf-w4 { transform: rotate(2.5deg); }
  .nf-w5 { transform: rotate(-2deg); position: relative; }
  .nf-w-circled { padding: 0 0.18em; }
  .nf-w-mark {
    position: absolute;
    inset: -0.18em -0.4em -0.22em -0.45em;
    color: var(--accent);
    transform: rotate(-1.4deg);
  }
  .nf-w6 {
    color: var(--accent);
    transform: translateY(0.1em);
  }

  .nf-lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 560px;
    margin: 0;
  }

  /* Suggestions */
  .nf-suggestions {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1.5px solid var(--ink);
    margin-top: 0.5rem;
  }
  .nf-suggestions li {
    border-bottom: 1px dashed var(--border-strong);
  }
  .nf-suggestion {
    display: grid;
    grid-template-columns: 60px 1fr 64px;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 0.5rem;
    color: var(--ink);
    transition: padding 0.3s ease, background-color 0.3s ease;
  }
  .nf-suggestion:hover {
    padding-left: 1.25rem;
    background: var(--bg-alt);
  }
  .nf-sugg-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--accent);
  }
  .nf-sugg-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.125rem, 1.6vw, 1.4rem);
    letter-spacing: -0.02em;
  }
  .nf-sugg-arrow {
    color: var(--muted);
    width: 56px;
    height: 18px;
    justify-self: end;
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 0.3s ease, color 0.3s ease, transform 0.4s ease;
  }
  .nf-suggestion:hover .nf-sugg-arrow {
    opacity: 1;
    color: var(--accent);
    transform: translateX(0);
  }

  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .btn-mark { width: 30px; height: 14px; }

  /* RIGHT — stamp */
  .nf-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
    padding-top: 1rem;
  }
  .nf-stamp {
    width: clamp(240px, 30vw, 360px);
    height: clamp(240px, 30vw, 360px);
    transform: rotate(-4deg);
    filter: drop-shadow(0 8px 22px rgba(0,0,0,0.18));
    animation: nf-stamp-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .nf-stamp svg { width: 100%; height: 100%; display: block; }
  .nf-stamp-note {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--muted);
    transform: rotate(-2deg);
    padding-right: 0.75rem;
  }

  @keyframes nf-stamp-in {
    0%   { transform: rotate(-22deg) scale(0.4); opacity: 0; }
    60%  { transform: rotate(-1deg) scale(1.05); opacity: 1; }
    100% { transform: rotate(-4deg) scale(1); opacity: 1; }
  }

  @media (max-width: 880px) {
    .nf-grid { grid-template-columns: 1fr; }
    .nf-right { align-items: flex-start; }
  }
</style>
