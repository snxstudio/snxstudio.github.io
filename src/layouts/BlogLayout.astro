---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readTime?: string;
}

const { title, description, date, category, readTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — SNX Studio`} description={description}>
  <Nav />
  <main>
    <article class="post">
      <header class="post-header">
        <div class="container-narrow">
          <div class="post-meta animate-fade-in-up">
            <span class="post-category">{category}</span>
            <span aria-hidden="true">·</span>
            <span>{formattedDate}</span>
            {readTime && (<><span aria-hidden="true">·</span><span>{readTime}</span></>)}
          </div>
          <h1 class="post-title animate-fade-in-up delay-200">{title}</h1>
          <p class="post-description animate-fade-in-up delay-300">{description}</p>
        </div>
      </header>

      <div class="post-content">
        <div class="container-narrow">
          <div class="prose">
            <slot />
          </div>
        </div>
      </div>

      <div class="post-footer">
        <div class="container-narrow post-footer-inner">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="17" y1="12" x2="7" y2="12"/>
              <polyline points="11,7 7,12 11,17"/>
            </svg>
            All field notes
          </a>
          <a href="/contact" class="back-cta">
            Want a teardown of your product? <span class="serif-italic">Let's talk →</span>
          </a>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style is:global>
  .prose {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 1.4vw, 1.3125rem);
    line-height: 1.7;
    color: var(--ink-2);
  }
  .prose > p:first-child::first-letter {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--accent);
    float: left;
    font-size: 4.5em;
    line-height: 0.85;
    margin: 0.05em 0.12em 0 -0.05em;
    letter-spacing: -0.05em;
  }
  .prose h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    color: var(--ink);
    margin: 3.5rem 0 1.25rem;
    line-height: 1.05;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .prose h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    color: var(--ink);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .prose p {
    margin-bottom: 1.5rem;
    color: var(--ink-2);
  }
  .prose strong {
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--ink);
    font-size: 0.92em;
  }
  .prose em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink);
  }
  .prose ul, .prose ol {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.6rem;
    color: var(--ink-2);
  }
  .prose ol {
    counter-reset: prose-list;
    list-style: none;
    padding-left: 0;
  }
  .prose ol > li {
    counter-increment: prose-list;
    padding-left: 2.25rem;
    position: relative;
  }
  .prose ol > li::before {
    content: counter(prose-list, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.1em;
    font-family: var(--font-mono);
    font-size: 0.75em;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 500;
  }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background-color: var(--bg-alt);
    padding: 0.15em 0.45em;
    border-radius: 4px;
    color: var(--ink);
    border: 1px solid var(--border);
  }
  .prose pre {
    background-color: var(--bg-alt);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 2rem 0;
    border: 1px solid var(--border);
    font-family: var(--font-mono);
  }
  .prose pre code {
    background: none;
    padding: 0;
    border: none;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .prose blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.5rem 0 0.5rem 1.75rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.3;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .prose hr {
    border: none;
    border-top: 1px dashed var(--border);
    margin: 3rem 0;
  }
  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose a:hover { text-decoration-thickness: 2px; }
</style>

<style>
  .post-header {
    padding-top: calc(78px + clamp(4rem, 8vw, 7rem));
    padding-bottom: clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid var(--border);
  }
  .post-meta {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .post-category { color: var(--accent); }
  .post-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.25rem, 6vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }
  .post-description {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.125rem, 1.6vw, 1.4rem);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 720px;
  }

  .post-content {
    padding: clamp(2.5rem, 5vw, 4.5rem) 0;
  }

  .post-footer {
    border-top: 1px solid var(--border);
    padding: clamp(2rem, 4vw, 3rem) 0;
    background: var(--bg-alt);
  }
  .post-footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-2);
    transition: color 0.25s ease;
  }
  .back-link:hover { color: var(--accent); }
  .back-link svg { transition: transform 0.25s ease; }
  .back-link:hover svg { transform: translateX(-3px); }

  .back-cta {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--ink);
    transition: color 0.25s ease;
  }
  .back-cta .serif-italic { color: var(--accent); font-weight: 400; }
  .back-cta:hover { color: var(--accent); }
</style>
